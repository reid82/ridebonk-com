---
const testflightUrl = "https://testflight.apple.com/join/zvuZuYu1";
const discordUrl = "https://discord.gg/pbcbxBxr";
const email = "reid@reidbates.com";
---
<aside class="subscribe-card">
  <h2>Want to try it?</h2>
  <p>
    It&apos;s on TestFlight. iOS for now, Android coming. New builds
    land as I push them, which lately is most days. Leave whenever
    you like.
  </p>
  <p class="cta-line">
    <a class="cta-btn" href={testflightUrl} rel="noopener" target="_blank">
      Join the TestFlight
    </a>
  </p>
  <p class="contact-line">
    Questions, comments, requests, abuse:
    <a href={`mailto:${email}`}>{email}</a>
    or come find me on
    <a href={discordUrl} rel="noopener" target="_blank">Discord</a>.
  </p>
</aside>

<style>
  .cta-line {
    margin: 1.1rem 0 0;
  }
  .cta-btn {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    padding: 0.6rem 1rem;
    background: var(--color-mustard);
    color: var(--color-ink);
    border: 1.5px solid var(--color-ink);
    text-decoration: none;
    box-shadow: 3px 3px 0 var(--color-ink);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .cta-btn:hover,
  .cta-btn:focus-visible {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-ink);
    outline: none;
  }
  .cta-btn:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--color-ink);
  }
  .contact-line {
    margin: 1.1rem 0 0;
    font-size: 0.95rem;
    opacity: 0.8;
  }
  .contact-line a {
    font-weight: 600;
    white-space: nowrap;
  }
</style>
